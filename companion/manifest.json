{
	"$schema": "../node_modules/@companion-module/base/assets/manifest.schema.json",
	"type": "connection",
	"id": "tidal",
	"name": "tidal",
	"shortname": "TIDAL",
	"description": "Authenticate against TIDAL, search the catalog, look up tracks/albums/playlists, and launch tidal:// URIs in the TIDAL desktop client. Works in Bitfocus Companion and Bitfocus Buttons.",
	"version": "0.4.0",
	"license": "MIT",
	"repository": "git+https://github.com/avimedia/companion-module-tidal.git",
	"bugs": "https://github.com/avimedia/companion-module-tidal/issues",
	"maintainers": [
		{
			"name": "Erlend Vage",
			"email": "avimedia@users.noreply.github.com",
			"github": "avimedia"
		}
	],
	"runtime": {
		"type": "node22",
		"api": "nodejs-ipc",
		"apiVersion": "0.0.0",
		"entrypoint": "../dist/main.js",
		"permissions": {
			"child-process": true
		}
	},
	"legacyIds": ["tidal-music"],
	"manufacturer": "TIDAL",
	"products": ["TIDAL"],
	"keywords": ["music", "streaming", "tidal", "audio", "catalog", "buttons", "companion"]
}
